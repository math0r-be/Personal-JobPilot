generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default("local")
  name      String   @default("")
  email     String   @default("")
  phone     String   @default("")
  location  String   @default("")
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiConfig {
  id        String   @id @default("active")
  provider  String   @default("openrouter")
  apiKey    String   @default("")
  baseUrl   String   @default("")
  model     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmtpConfig {
  id        String   @id @default("active")
  host      String   @default("")
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String   @default("")
  pass      String   @default("")
  fromName  String   @default("")
  fromEmail String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoverLetter {
  id           String      @id @default(cuid())
  title        String      @default("Lettre de motivation")
  body         String
  cvId         String
  cv           Cv          @relation(fields: [cvId], references: [id], onDelete: Cascade)
  jobPostingId String?
  jobPosting   JobPosting? @relation(fields: [jobPostingId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Cv {
  id            String         @id @default(cuid())
  title         String         @default("Mon CV")
  content       String         @default("{}")
  templateId    String         @default("classic")
  jobPostingId  String?
  jobPosting    JobPosting?    @relation(fields: [jobPostingId], references: [id])
  coverLetters  CoverLetter[]
  matchScore    Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model JobPosting {
  id           String         @id @default(cuid())
  title        String         @default("")
  company      String         @default("")
  location     String         @default("")
  rawText      String
  parsedData   String         @default("{}")
  status       String         @default("new")
  cvs          Cv[]
  coverLetters CoverLetter[]
  emails       Email[]
  notes        String         @default("")
  appliedAt    DateTime?
  url          String         @default("")
  source       String?
  salary       String?
  followUpDate DateTime?
  activities   ActivityLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ActivityLog {
  id          String     @id @default(cuid())
  jobId       String
  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime   @default(now())
}

model Email {
  id           String      @id @default(cuid())
  jobPostingId String?
  jobPosting   JobPosting? @relation(fields: [jobPostingId], references: [id])
  to           String
  subject      String
  body         String
  status       String      @default("draft")
  sentAt       DateTime?
  errorMsg     String?
  createdAt    DateTime    @default(now())
}
